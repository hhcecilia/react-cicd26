{
    "requiresCompatibilities": [
        "FARGATE"
    ],
    "family": "reactcicd-task",
    "containerDefinitions": [
        {
            "name": "reactcicd-container",
            "image": "IMAGE_PLACEHOLDER",
            "portMappings": [
                {
                    "containerPort": 80,
                    "hostPort": 80,
                    "protocol": "tcp",
                    "appProtocol": "http"
                }
            ],
            "essential": true
        }
    ],
    "volumes": [],
    "networkMode": "awsvpc",
    "memory": "512",
    "cpu": "256",
    "executionRoleArn": "arn:aws:iam::268769775545:role/ecsTaskExecutionRole"
}